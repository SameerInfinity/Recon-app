# ══════════════════════════════════════
# BUILD MANAGER — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════

# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Upstash Redis (https://upstash.com → Create Database → REST API)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Google Gemini AI (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Sign-In — Web OAuth Client ID (Google Cloud Console → Credentials)
# This is the SAME "Web application" client ID already configured in
# Supabase → Authentication → Providers → Google. Used by the native
# Android/iOS app to request a Google ID token in-app (no browser).
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Server
PORT=8080
