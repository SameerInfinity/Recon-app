{
  "name": "arconza-buildmanager",
  "version": "2.0.0",
  "description": "ARCONZA — AI-Powered Construction Management & Dynamic Financial Ledger",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "cap:init": "npx cap init",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npx cap run android",
    "cap:build:android": "npx cap build android",
    "dev:android": "node scripts/setup-livereload.js",
    "build:android": "node scripts/build-native-config.js && npx cap sync android",
    "deploy:functions": "supabase functions deploy ai-chat --no-verify-jwt && supabase functions deploy delete-user",
    "functions:serve": "supabase functions serve"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capgo/capacitor-social-login": "^8.3.27",
    "@supabase/supabase-js": "^2.45.0",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.2.0"
  }
}
